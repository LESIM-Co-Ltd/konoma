---
// Animated hero terminal: konoma's core loop (full-screen Tree ⇄ full-screen Preview)
// drawn in HTML/CSS instead of a screenshot. Deliberately dark in both site themes —
// it depicts a terminal. Honors prefers-reduced-motion (static Preview frame).
interface Props {
	lang?: 'en' | 'ja';
}
const { lang = 'en' } = Astro.props;
const t =
	lang === 'ja'
		? {
				aria: 'konoma のツリー画面とプレビュー画面が切り替わるデモ',
				toggleNote: 'Space でトグル、ファイルに書き戻る',
				linkNote: '← Tab でフォーカス・↵ で開く',
				today: '今日',
			}
		: {
				aria: 'Demo of konoma switching between its tree and preview screens',
				toggleNote: 'Space toggles, written back to the file',
				linkNote: '← Tab focuses, ↵ opens',
				today: 'today',
			};
---

<div class="term" role="img" aria-label={t.aria}>
	<div class="term-bar">
		<span class="dot"></span><span class="dot"></span><span class="dot"></span>
		<span class="term-title">konoma — ~/work/app</span>
		<span class="term-mode">TREE ⇄ PREVIEW</span>
	</div>
	<div class="screens">
		<div class="screen tree">
			<div class="trow thead"><span class="chip">TREE</span>&nbsp;&nbsp;sort: name ↑ · path: rel</div>
			<div class="trow dim">┌ app ─────────────────────────────────────────────┐</div>
			<div class="trow">│ ▸&nbsp;&nbsp;src&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="dim">--&nbsp;&nbsp;&nbsp;06-30 09:12</span> │</div>
			<div class="trow sel">│&nbsp;&nbsp;&nbsp;&nbsp;<span class="mark">M</span> README.md&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="dim">4.2 KB&nbsp;&nbsp;{t.today} 14:02</span> │<span class="cursor"></span></div>
			<div class="trow">│&nbsp;&nbsp;&nbsp;&nbsp;<span class="mark">M</span> app.rs&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="dim">18.6 KB&nbsp;&nbsp;{t.today} 14:01</span> │</div>
			<div class="trow">│&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Cargo.toml&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="dim">1.1 KB&nbsp;&nbsp;06-28 18:40</span> │</div>
			<div class="trow">│&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sample.pdf&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="dim">312 KB&nbsp;&nbsp;06-27 11:05</span> │</div>
			<div class="trow">│&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;data.csv&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="dim">8.4 KB&nbsp;&nbsp;06-27 10:58</span> │</div>
			<div class="trow dim">└──────────────────────────────────────────────────┘</div>
			<div class="foot">j/k:move&nbsp;&nbsp;↵:preview&nbsp;&nbsp;/:filter&nbsp;&nbsp;o:git&nbsp;&nbsp;F:follow&nbsp;&nbsp;?:help</div>
		</div>
		<div class="screen preview">
			<div class="trow thead"><span class="chip">PREVIEW</span>&nbsp;&nbsp;README.md</div>
			<div class="trow">&nbsp;</div>
			<div class="trow md-h">Release checklist</div>
			<div class="trow md-rule">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
			<div class="trow"><span class="on"></span>&nbsp;&nbsp;bump version <span class="dim">— {t.toggleNote}</span></div>
			<div class="trow"><span class="on"></span>&nbsp;&nbsp;update changelog</div>
			<div class="trow"><span class="dim"></span>&nbsp;&nbsp;tag &amp; publish</div>
			<div class="trow">&nbsp;</div>
			<div class="trow">docs: <span class="md-link">CONFIGURATION.md</span> <span class="dim">{t.linkNote}</span></div>
			<div class="foot">Tab:link&nbsp;&nbsp;Space:toggle&nbsp;&nbsp;/:search&nbsp;&nbsp;R:raw&nbsp;&nbsp;q:back</div>
		</div>
	</div>
</div>

<style>
	/* Fixed comp palette on purpose: a terminal window stays dark in light mode too. */
	.term {
		--t-ink: #0e1310;
		--t-pane: #141b16;
		--t-line: #253128;
		--t-moss: #3e9b63;
		--t-leaf: #a7d3a0;
		--t-paper: #e9efe6;
		--t-bark: #87927f;
		--t-amber: #d9a94e;
		margin: 2.5rem auto 0;
		max-width: 46rem;
		border: 1px solid var(--t-line);
		border-radius: 10px;
		background: var(--t-pane);
		overflow: hidden;
		box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
		text-align: left;
	}
	.term-bar {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 10px 14px;
		border-bottom: 1px solid var(--t-line);
		font-family: var(--konoma-mono, monospace);
		font-size: 12px;
		color: var(--t-bark);
	}
	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--t-line);
	}
	.term-title {
		margin-left: 10px;
	}
	.term-mode {
		margin-left: auto;
		color: var(--t-moss);
	}
	.screens {
		position: relative;
		height: 21rem;
		font-family: var(--konoma-mono, monospace);
		font-size: 0.82rem;
		line-height: 1.9;
		background: var(--t-ink);
	}
	.screen {
		position: absolute;
		inset: 0;
		padding: 14px 20px;
		opacity: 0;
		overflow: hidden;
	}
	.screen.tree {
		animation: showA 9s infinite;
	}
	.screen.preview {
		animation: showB 9s infinite;
	}
	@keyframes showA {
		0%,
		44% {
			opacity: 1;
		}
		50%,
		94% {
			opacity: 0;
		}
		100% {
			opacity: 1;
		}
	}
	@keyframes showB {
		0%,
		44% {
			opacity: 0;
		}
		50%,
		94% {
			opacity: 1;
		}
		100% {
			opacity: 0;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.screen.tree,
		.screen.preview {
			animation: none;
		}
		.screen.preview {
			position: relative;
			opacity: 1;
		}
		.screen.tree {
			display: none;
		}
		.cursor {
			animation: none;
		}
	}
	.trow {
		white-space: pre;
		color: var(--t-paper);
	}
	.trow .dim,
	.trow.dim {
		color: var(--t-bark);
	}
	.trow .mark {
		color: var(--t-moss);
		font-weight: 600;
	}
	.trow.sel {
		background: rgba(62, 155, 99, 0.16);
		border-radius: 3px;
	}
	.thead {
		color: var(--t-bark);
	}
	.thead .chip {
		color: var(--t-ink);
		background: var(--t-leaf);
		padding: 1px 7px;
		border-radius: 3px;
		font-weight: 600;
	}
	.foot {
		position: absolute;
		left: 20px;
		right: 20px;
		bottom: 10px;
		color: var(--t-bark);
		font-size: 0.72rem;
		border-top: 1px solid var(--t-line);
		padding-top: 8px;
		white-space: pre;
		overflow: hidden;
	}
	.md-h {
		color: var(--t-leaf);
		font-weight: 700;
		font-size: 1rem;
	}
	.md-rule {
		color: var(--t-line);
	}
	.on {
		color: var(--t-moss);
	}
	.md-link {
		background: var(--t-leaf);
		color: var(--t-ink);
		padding: 0 2px;
		font-weight: 600;
	}
	.cursor {
		display: inline-block;
		width: 8px;
		height: 1rem;
		background: var(--t-amber);
		vertical-align: -2px;
		animation: blink 1.2s steps(1) infinite;
	}
	@keyframes blink {
		50% {
			opacity: 0;
		}
	}
	@media (max-width: 40rem) {
		.screens {
			font-size: 0.62rem;
			height: 17rem;
		}
	}
</style>
